          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.token || res.accessToken;",
                  "if (token) {",
                  "  pm.environment.set(\"token\", token);",
                  "}",
                  "if (res?.data?.id) {",
                  "  pm.environment.set(\"userId\", res.data.id);",
